# AI Gateway — required for live LLM + embedding calls
# Get from: vercel env pull --environment=development  (if linked)
# Or set manually after creating an AI Gateway in the Vercel dashboard
AI_GATEWAY_API_KEY=

# Optional — used by the orchestrator's searchCorpus tool to call /api/search internally.
# Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_BASE_URL=
